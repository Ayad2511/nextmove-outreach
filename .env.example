# ============================================
# Next Move Marketing — Outreach Systeem
# Kopieer naar .env.local en vul in
# ============================================

# Database (automatisch ingesteld door Render)
DATABASE_URL=postgresql://user:password@host:5432/nextmove

# ---- Apify (Instagram scraper + DM automation) ----
# Haal op via: console.apify.com → Settings → Integrations → API tokens
APIFY_API_KEY=
# Instagram sessie cookie voor DM automation (sessionid cookie waarde uit browser)
INSTAGRAM_SESSION_ID=

# ---- VSL / Video Sales Letter ----
# Publieke URL van jouw VSL pagina — wordt meegestuurd in emails
VSL_URL=

# ---- Clay (Lead enrichment) ----
# Haal op via: app.clay.com → Settings → API
CLAY_API_KEY=
CLAY_TABLE_ID=

# ---- Lemlist (Cold email, 40/dag) ----
# Haal op via: app.lemlist.com → Settings → Integrations → API
LEMLIST_API_KEY=
LEMLIST_CAMPAIGN_ID=

# ---- Phantombuster (LinkedIn + Instagram warming) ----
# Haal op via: phantombuster.com → Account → API Key
PHANTOMBUSTER_API_KEY=
# ID van "LinkedIn Auto Connect" phantom
PHANTOMBUSTER_LINKEDIN_AGENT_ID=
# ID van "Instagram Auto Liker" phantom (warming stap 1)
PHANTOMBUSTER_LIKER_AGENT_ID=
# ID van "Instagram Story Viewer" phantom (warming stap 2, optioneel)
PHANTOMBUSTER_STORY_AGENT_ID=
# ID van "Instagram Story Viewer + DM" phantom (oud, optioneel)
PHANTOMBUSTER_INSTAGRAM_AGENT_ID=

# ---- HeyGen (Gepersonaliseerde video per prospect) ----
# Haal op via: app.heygen.com → API → API Keys
HEYGEN_API_KEY=
HEYGEN_TEMPLATE_ID=
# Zet dit in als geheime waarde in Render dashboard
HEYGEN_WEBHOOK_SECRET=

# ---- App configuratie ----
NEXTAUTH_SECRET=genereer-met-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Development
NODE_ENV=development
